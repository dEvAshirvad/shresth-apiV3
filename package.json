	"scripts": {
		"dev": "cross-env nodemon src/index.ts",
		"worker:dev": "cross-env tsx src/worker.ts",
		"start": "cross-env node dist/index.js",
		"start:worker": "cross-env node dist/worker.js",
		"prepare": "husky",
		"build": "rm -rf ./dist && tsc && tsc-alias",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"clean:install": "rm -rf ./node_modules && rm -r package-lock.json && pnpm i",
		"clean:find-unused": "knip",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"format": "prettier --write ."
	},
